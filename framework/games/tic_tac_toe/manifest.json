{
  "name": "tic_tac_toe",
  "display_name": "Tic Tac Toe",
  "version": "1.0.0",
  "min_players": 2,
  "max_players": 2,
  "description": "N×N grid; configurable win length (k in a row)",
  "config_schema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "oneOf": [
      { "type": "null" },
      {
        "type": "object",
        "required": ["side_length", "win_length"],
        "properties": {
          "side_length": { "type": "integer", "minimum": 2, "maximum": 20 },
          "win_length": { "type": "integer", "minimum": 2, "maximum": 20 }
        },
        "additionalProperties": false
      }
    ]
  },
  "built_with": {
    "cli_version": "0.1.0",
    "framework_version": "0.1.0",
    "wit_version": "game-core-v2",
    "sdk_versions": {
      "upjs-gdd-shared-types": "0.1.0",
      "upjs-gdd-rust-shared": "0.1.0",
      "upjs-gdd-bevy": "0.1.0",
      "upjs-gdd-dioxus": "0.1.0",
      "@upjs-gdd/game-sdk": "0.1.0",
      "@upjs-gdd/sdk-js": "0.1.0",
      "sk.upjs.gdd:game": "0.1.0"
    }
  }
}
