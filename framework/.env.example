# Copy to .env on the deployment host (never commit .env).

# Container image (set by CI or pin a release tag)
GAMEDEV_IMAGE=ghcr.io/matusem/ipel-gamedev:latest

# Host port on the Pi (container always listens on 8080 internally)
HOST_PORT=8090
# 127.0.0.1 = localhost only; 0.0.0.0 = all interfaces (LAN)
BIND_HOST=127.0.0.1

# Runtime (passed into the container)
HOST=0.0.0.0
PORT=8080
DATABASE_URL=sqlite:///app/data/app.db
GAMES_DIR=/app/games
DRAFTS_DIR=/app/drafts
LOBBY_DIR=/app/lobby
LIB_DIR=/app/lib
PLATFORM_MANIFEST_DIR=/app/platform
TOOLS_DIR=/app/tools

# Upload policy
# REQUIRE_BUILT_WITH_METADATA=true
# OPEN_DEVELOPER_UPLOADS=false

# Deploy webhook (Ed25519 public key — see scripts/generate-deploy-keys.py)
# DEPLOY_WEBHOOK_PUBLIC_KEY=
# Shared with GitHub secret DEPLOY_WEBHOOK_TOKEN (Cloudflare WAF bypass + app check)
# DEPLOY_WEBHOOK_TOKEN=
# DEPLOY_COMPOSE_DIR=/deploy
